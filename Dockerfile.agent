# ═══════════════════════════════════════════════════
# SentinelStream - Python Log Exporter Agent
# ═══════════════════════════════════════════════════
FROM python:3.11-slim

LABEL maintainer="thtcsec"
LABEL description="SentinelStream Monitoring Agent - Streams server logs to War Room"

WORKDIR /app

# Install dependencies
COPY agent/log_exporter.py .
COPY agent/requirements.txt .

RUN pip install --no-cache-dir -r requirements.txt

EXPOSE 8000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/')" || exit 1

CMD ["uvicorn", "log_exporter:app", "--host", "0.0.0.0", "--port", "8000"]
