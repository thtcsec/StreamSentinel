# --- Agora Configuration ---
AGORA_APP_ID=your_agora_app_id_here
AGORA_APP_CERTIFICATE=your_agora_certificate_here

# --- Security Configuration ---
# Khóa 32-byte cho AES-256 (Dùng để mã hóa stream)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# Salt để băm (hash) file ghi âm forensics
FORENSIC_SALT=somesupersecret-salt-value

# Ghi file log war room + báo cáo SHA-256 khi bấm Leave (cần FORENSIC_SALT khác rỗng)
SESSION_EXPORT_ON_LEAVE=false
# SESSION_EXPORT_DIRECTORY=C:\Exports

# --- Log agent (Python WebSocket) — empty = app does not connect ---
LOG_SERVER_URL=ws://127.0.0.1:8000/ws/logs

# Simulated SOC log lines in the WPF app (set false when using only a real agent)
DEMO_LOG_FEED=true
